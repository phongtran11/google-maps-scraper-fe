{
  "name": "google-maps-scraper-fe",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "export $(grep -v '^#' .env | xargs) && react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-types": "export $(grep -v '^#' .env | xargs) && npx @neondatabase/neon-js gen-types --db-url \"$NEON_DATABASE_URL\" --output app/types/database.ts",
    "invite": "npx tsx --env-file=.env scripts/invite.ts",
    "migrate": "npx tsx --env-file=.env scripts/migrate.ts",
    "db:studio": "npx drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/neon-js": "0.6.1-beta",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.15",
    "@react-router/node": "7.15.1",
    "@react-router/serve": "7.15.1",
    "better-auth": "^1.6.11",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5.1.36",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "7.15.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@react-router/dev": "7.15.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "4.1.7",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7"
  }
}
